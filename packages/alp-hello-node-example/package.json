{
  "name": "alp-hello-node-example",
  "version": "13.1.0",
  "private": true,
  "homepage": "https://github.com/christophehurpeau/alp",
  "license": "MIT",
  "author": "Christophe Hurpeau <christophe@hurpeau.com> (https://christophe.hurpeau.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/christophehurpeau/alp.git",
    "directory": "packages/alp-hello-node-example"
  },
  "type": "module",
  "main": "./build/index-node.mjs",
  "imports": {
    "#/*": "./src/*"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./src/index.ts",
      "node": {
        "import": "./build/index-node.mjs"
      }
    }
  },
  "scripts": {
    "build": "yarn run clean:build && rollup --config rollup.config.mjs",
    "clean": "yarn run clean:build",
    "clean:build": "pob-esbuild-clean-out build",
    "lint": "yarn run lint:eslint",
    "lint:eslint": "yarn '../..' run eslint --quiet 'packages/alp-hello-node-example'",
    "start": "yarn run clean:build && rollup --config rollup.config.mjs --watch",
    "tsc": "tsc"
  },
  "dependencies": {
    "alp-node": "10.1.0",
    "alp-node-auth": "13.1.0",
    "liwi-mongo": "12.0.0",
    "nightingale-app-console": "16.2.0",
    "nightingale-web-processor": "16.0.0",
    "router-segments": "12.0.0"
  },
  "devDependencies": {
    "@pob/rollup-esbuild": "9.1.1",
    "alp-rollup-plugin-config": "4.1.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=24.14.1"
  },
  "pob": {
    "bundler": "rollup-esbuild",
    "entries": [
      "index"
    ],
    "envs": [
      {
        "target": "node",
        "version": "24",
        "omitVersionInFileName": true
      }
    ],
    "typescript": true
  }
}
